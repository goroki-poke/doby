{
  "name": "jsonld-api",
  "version": "1.0.0",
  "description": "JSON-LD Schema Generator API — Generate Google-compliant structured data from raw page metadata, blog content, or product details.",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
